# 브라우저가 호출하는 API base — 동일 출처 프록시(/api) 권장.
# next.config rewrites가 BACKEND_PROXY_ORIGIN으로 중계하여 CORS/쿠키 문제를 우회한다.
# (로컬에서 직접 백엔드 origin을 쓰려면 백엔드 CORS·SameSite=None 설정이 선행되어야 함)
NEXT_PUBLIC_API_BASE_URL=/api

# rewrites 프록시 대상 백엔드 origin (서버 사이드 전용)
BACKEND_PROXY_ORIGIN=https://sdg-backend-307053111333.asia-northeast3.run.app

# mock 유지 토글 (true: MSW mock / false: 실제 API 호출)
NEXT_PUBLIC_USE_MOCK=false

NEXT_PUBLIC_APP_ENV=development

# 역지오코딩(GPS 좌표 → 행정구역명) 서버 전용 키.
# Kakao Developers > 내 애플리케이션 > REST API 키.
# 서버(/geocode 라우트)에서만 사용하므로 NEXT_PUBLIC_ 접두사를 붙이지 않는다(브라우저 비노출).
# 미설정 시 진단 위치는 폴백("경기도 이천시")으로 동작한다.
KAKAO_REST_KEY=
