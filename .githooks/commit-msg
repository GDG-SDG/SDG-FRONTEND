#!/bin/sh
# commit-msg hook
# AI 자동 생성 co-author 트레일러(예: "Co-Authored-By: Claude ...")가
# 커밋 메시지에 들어가지 않도록 자동 제거한다.
# 사람 간 정상 co-author는 유지한다(Claude/Anthropic 트레일러만 대상).
#
# 활성화: git config core.hooksPath .githooks  (npm install 시 prepare 스크립트가 자동 설정)

msg_file="$1"
[ -f "$msg_file" ] || exit 0

# Claude / Anthropic AI 트레일러 라인 제거 + 끝쪽 빈 줄 정리
perl -0pi -e '
  s/^[ \t]*Co-[Aa]uthored-[Bb]y:.*(?:[Cc]laude|[Aa]nthropic|anthropic\.com).*\R//mg;
  s/\R+\z/\n/;
' "$msg_file"

exit 0
